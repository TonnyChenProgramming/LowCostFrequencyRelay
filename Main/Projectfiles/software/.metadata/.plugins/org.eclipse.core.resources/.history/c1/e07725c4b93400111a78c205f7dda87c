    // Mimic the Analyser: 320 count = 50Hz
    msg.adcCount = 320;
    //printf(".2%f", msg);

    //enum to swap modes
    if(current_system_mode == MAINTENANCE){
    	current_system_mode = LOAD_MANAGING;
