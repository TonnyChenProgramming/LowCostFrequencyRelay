static void T_SwitchPolling(void *pvParameters)
{
	  unsigned int uiSwitchValue = 0;
	  LoadCtrlMessage outMsg;
	  for (;;)
	  {
		   uiSwitchValue = IORD_ALTERA_AVALON_PIO_DATA(SLIDE_SWITCH_BASE);
		   outMsg.producer_id = 0;
		   outMsg.switch_state = (uint8_t)uiSwitchValue;
		   xQueueSendToBack(Q_newLoadCtrl, &outMsg, portMAX_DELAY);
		   vTaskDelay(pdMS_TO_TICKS(1000));
	  }
}

static void T_StabilityMonitor(void *pvParameters){
	FreqRocMessage receivedMsg;
	LoadCtrlMessage outMsg;

	  for (;;)
	  {
		if (xQueueReceive(Q_newFreqToMonitor, &receivedMsg, portMAX_DELAY) == pdPASS)
		{
			outMsg.producer_id = 1;
			outMsg.stability_state = 0;
			uint8_t low_freq_flag = receivedMsg.frequencyHz < (double )LOW_FREQ_THRESHOLD;
			uint8_t high_roc_flag = fabs(receivedMsg.rocHzPerSec) > (double)HIGH_ROC_THRESHOLD;
			outMsg.stability_state = low_freq_flag | high_roc_flag;

			xQueueSendToBack(Q_newLoadCtrl, &outMsg, portMAX_DELAY);
		}
	  }
}

static void T_LoadCtrl(void *pvParameters)
{
    LoadCtrlMessage receivedMsg;

    (void)pvParameters; // Prevent compiler warning for unused parameter

    static uint8_t current_user_switch_input;
    static uint8_t empty_mask = 0; // used to clear leds
    (void) pvParameters; // Prevent compiler warning for unused parameter


    for (;;)
    {
        /* Listen to the Q_newFreqToVGA queue */
        if (xQueueReceive(Q_newLoadCtrl, &receivedMsg, portMAX_DELAY) == pdPASS)
        {
            // Parse the correct information based on packet id
            if (receivedMsg.producer_id == 0)
            {
                current_user_switch_input = receivedMsg.switch_state & 0x1F;
            }
            else if (receivedMsg.producer_id == 1)
            {
                currentNetworkUnstable = receivedMsg.stability_state;
            }

            // Update LEDs mask based on current system state,
            // and latest switch + stability state

            if (current_system_mode == MAINTENANCE)
            {
            	//printf("enter the maintenance branch\n");
                // In maintenance state, only switches control the load
            	number_of_activated_loads = calculateNumberOfSwitchOn(current_user_switch_input);
            	shedLoadMask = current_user_switch_input;
            	printf("%d\n",number_of_activated_loads);
            	xQueueSendToBack(Q_newGreenLed, &current_user_switch_input, portMAX_DELAY);
            	xQueueSendToBack(Q_newRedLed, &empty_mask, portMAX_DELAY);//clear all red LEDs
            }
            else if (current_system_mode == LOAD_MANAGING)
            {
            	//printf("enter the load managing branch\n");
            	//clear all green LEDs
            	xQueueSendToBack(Q_newGreenLed, &empty_mask, portMAX_DELAY);

                if (receivedMsg.producer_id == 1)
                {
                	if (prevNetworkUnstable != currentNetworkUnstable)
                	{
                		if (number_of_activated_loads == MAXIMUM_LOAD_NUMBER)
                		{
                			shedLoadMask = removeLowestPriority(MAXIMUM_LOAD_NUMBER,shedLoadMask);
                			prevNetworkUnstable = currentNetworkUnstable;
                		} else{
                			xTimerReset(xManageTimer, 0);
                			//timer reset
                		}

                	}

                }
                shedLoadMask = shedLoadMask & current_user_switch_input;
                number_of_activated_loads = calculateNumberOfSwitchOn(shedLoadMask);

                xQueueSendToBack(Q_newRedLed, &shedLoadMask, portMAX_DELAY);
            }

        }
    }
}
