void vTimerCallback(xTimerHandle t_timer){
	printf("enterrrrrrrrrrrrr\n");
    if ((!prevNetworkUnstable) && currentNetworkUnstable)
    {
    	printf("shed/n");
		shedLoadMask = removeLowestPriority(MAXIMUM_LOAD_NUMBER,shedLoadMask);
		printf("500ms unstable -> shed next load, mask = 0x%X\n", shedLoadMask);
		/* continue observing unstable if still unstable */
		prevNetworkUnstable = currentNetworkUnstable; // update previous state
		xTimerReset(xManageTimer, 0);
    }
    else if ((!currentNetworkUnstable)&& prevNetworkUnstable)
    {
    	printf("recover/n");
		shedLoadMask = recoverHighestPriority(MAXIMUM_LOAD_NUMBER,shedLoadMask);
		printf("500ms stable -> reconnect one load, mask = 0x%X\n", shedLoadMask);
		/* continue observing stable if still stable */
		prevNetworkUnstable = currentNetworkUnstable;
		xTimerReset(xManageTimer, 0); //update previous state

    }

}

