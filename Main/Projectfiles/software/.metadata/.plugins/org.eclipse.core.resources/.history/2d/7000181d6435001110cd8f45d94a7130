uint8_t removeLowestPriority(uint8_t size, uint8_t bitmask)
{
	if (number_of_activated_loads >0)
	{
	    for (uint8_t counter = 0; counter < size; counter++)
	    {
	        if (bitmask & (1 << counter))  // found first ON bit
	        {
	            bitmask &= ~(1 << counter); // clear that bit
	            break; // only remove one
	        }
	    }
	    number_of_activated_loads;
	}

    return bitmask;
}

uint8_t recoverHighestPriority(uint8_t size, uint8_t bitmask)
{
	if (number_of_activated_loads < MAXIMUM_LOAD_NUMBER)
	{
	    for (int8_t counter = size - 1; counter >= 0; counter--)
	    {
	        if (!(bitmask & (1 << counter)))  // find first OFF bit
	        {
	            bitmask |= (1 << counter);   // turn it ON
	            break;
	        }
	    }
	}

    return bitmask;
}
uint8_t calculateNumberOfSwitchOn(uint16_t current_user_switch_input)
{
	uint8_t numberOfSwitchOn;
	numberOfSwitchOn = 0;
    for (uint8_t counter = 0; counter < MAXIMUM_LOAD_NUMBER; counter++)
    {
        if (current_user_switch_input & (1 << counter))  // found first ON bit
        {
        	numberOfSwitchOn++;
        }
    }
    return numberOfSwitchOn;
}

