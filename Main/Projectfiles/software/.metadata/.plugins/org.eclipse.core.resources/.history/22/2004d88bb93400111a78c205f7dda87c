static void vManageTimerCallback(TimerHandle_t xTimer)
{
    (void)xTimer;

    if (observeState == OBSERVE_UNSTABLE)
    {
        if (currentNetworkUnstable)
        {
        	shedLoadMask = removeLowestPriority(shedLoadMask);
        	number_of_activated_loads --;
            printf("500ms unstable -> shed next load, mask = 0x%X\n", currentLoadMask);
            /* continue observing unstable if still unstable */
            xTimerReset(xManageTimer, 0);

        }
    }
    else if (observeState == OBSERVE_STABLE)
    {
        if (!currentNetworkUnstable)
        {
        	shedLoadMask = recoverHighestPriority(shedLoadMask);
        	number_of_activated_loads ++;
            printf("500ms stable -> reconnect one load, mask = 0x%X\n", currentLoadMask);
            /* continue observing stable if still stable */
            xTimerReset(xManageTimer, 0);
        }
    }
}
