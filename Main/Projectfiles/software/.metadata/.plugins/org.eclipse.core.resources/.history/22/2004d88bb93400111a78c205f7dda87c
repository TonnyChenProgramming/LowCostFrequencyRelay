void FreqAnalyserISR(void *context)
{
    AdcCountMessage msg;

    (void)context;

    msg.adcCount = IORD(FREQUENCY_ANALYSER_BASE, 0);
    xQueueSendToBackFromISR(Q_adcCount, &msg, NULL);
}

