 *
 * ALT_CLOSE is mapped onto the close() system call in alt_syscall.h
 */
 
int ALT_CLOSE (int fildes)
{
   16e0c:	defffb04 	addi	sp,sp,-20
   16e10:	dfc00415 	stw	ra,16(sp)
